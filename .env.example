# AI Novel Backend 环境变量配置
# 复制此文件为 .env 并填入真实值

# ========== 服务器配置 ==========
SERVER_PORT=8080
SERVER_MODE=debug

# ========== Neon PostgreSQL 数据库 ==========
# 替换为你的 Neon 连接字符串
