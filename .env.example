# AI Novel Backend 环境变量配置
# 复制此文件为 .env 并填入真实值

# ========== 服务器配置 ==========
SERVER_PORT=8080
SERVER_MODE=debug

# ========== Neon PostgreSQL 数据库 ==========
# 替换为你的 Neon 连接字符串
DATABASE_URL=postgres://neondb_owner:npg_KWMXeQcI81uV@ep-spring-queen-a1ekmm52-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ========== Pinecone 向量数据库 ==========
PINECONE_API_KEY=pcsk_3NmcAc_KHxduBmPWGuJvJ9pFsmJR6rjU7iNq3MMRCXtQAFSJw8v233dzGBDiPV2bGysBBU
PINECONE_INDEX_NAME=ai-novel-index
PINECONE_NAMESPACE=novel-embeddings

# ========== JWT 认证 ==========
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================================
# LLM 配置 - 选择一个并取消注释
# ============================================================

# --- DeepSeek (默认) ---
# LLM_PROVIDER=deepseek
# LLM_BASE_URL=https://api.deepseek.com
# LLM_MODEL=deepseek-chat
# DEEPSEEK_API_KEY=your-deepseek-api-key

# --- OpenAI ---
# LLM_PROVIDER=openai
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=your-openai-api-key

# --- MiniMax (M2.5) ---
# LLM_PROVIDER=minimax
# LLM_BASE_URL=https://api.minimaxi.com/v1
# LLM_MODEL=MiniMax-M2.5
# MINIMAX_API_KEY=your-minimax-api-key

# --- 智谱 AI (GLM-5 / GLM-4.7) ---
# LLM_PROVIDER=zhipu
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-5
# ZHIPU_API_KEY=your-zhipu-api-key

# --- 月之暗面 (Kimi K2.5) ---
# LLM_PROVIDER=moonshot
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=kimi-k2.5
# MOONSHOT_API_KEY=your-moonshot-api-key

# ============================================================
# 可用模型列表
# ============================================================
# DeepSeek: deepseek-chat, deepseek-coder
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo, o1-preview
# MiniMax: MiniMax-M2.5, MiniMax-Text-01
# 智谱 AI: glm-5, glm-4-air, glm-4-flash, glm-4-long, glm-4v
# 月之暗面: kimi-k2.5, kimi-latest, kimi-plus, kimi-vision
