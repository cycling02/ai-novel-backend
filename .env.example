# ========== Pinecone 向量数据库 ==========
PINECONE_API_KEY=pcsk_3NmcAc_KHxduBmPWGuJvJ9pFsmJR6rjU7iNq3MMRCXtQAFSJw8v233dzGBDiPV2bGysBBU
PINECONE_INDEX_NAME=ai-novel-index
